# Citadel example environment / node notes
# Copy ideas into your local .env if you use one — do not commit real secrets.
# The Tauri UI also stores node URL via Settings (configure_node); this file is docs.

# Default Scala/official node REST port
# NODE_URL=http://127.0.0.1:9053

# ergo-rust-node default REST (see /info → restApiUrl)
# NODE_URL=http://127.0.0.1:9063

# Optional API key for authenticated wallet endpoints (usually empty for local)
# NODE_API_KEY=

# Citadel needs extraIndex / indexer for balances, UTXOs, protocol box lookups.
# Official node: set extraIndex = true in node config.
# ergo-rust-node: enable the indexer so GET /blockchain/indexedHeight returns 200.
